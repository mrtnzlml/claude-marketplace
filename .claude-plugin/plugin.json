{
  "name": "rossum",
  "description": "Claude Code plugin for Rossum.ai workflows",
  "version": "0.1.0",
  "author": {
    "name": "mrtnzlml"
  },
  "mcpServers": {
    "rossum-api": {
      "command": "python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-servers/rossum-api/server.py"],
      "env": {
        "ROSSUM_API_BASE": "${ROSSUM_API_BASE:-https://elis.rossum.ai}",
        "ROSSUM_TOKEN": "${ROSSUM_TOKEN:-}"
      }
    }
  }
}
